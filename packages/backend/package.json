{
  "name": "@repo/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "convex dev --tail-logs",
    "deploy": "convex deploy",
    "setup": "convex dev --once",
    "typecheck": "tsc --noEmit",
    "lint:prompt-drift": "bun run scripts/lint-prompt-drift.ts",
    "test": "vitest run --typecheck",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --typecheck --clearScreen false"
  },
  "exports": {
    "./_generated/api": "./convex/_generated/api.js",
    "./_generated/dataModel": "./convex/_generated/dataModel.js",
    "./schema": "./convex/schema.ts",
    "./types": "./convex/types.ts",
    "./functions": "./convex/functions.ts",
    "./permissions": "./convex/permissions.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@clerk/backend": "^2.24.0",
    "@convex-dev/agent": "^0.6.1",
    "@convex-dev/rag": "^0.7.2",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "^0.2.1",
    "@convex-dev/workflow": "^0.3.11",
    "@crowdevelopment/convex-plaid": "workspace:*",
    "@internationalized/date": "^3.10.1",
    "@react-email/components": "^0.4.0",
    "@react-email/render": "^2.0.0",
    "@react-stately/utils": "^3.11.0",
    "@repo/email": "workspace:*",
    "ai": "^6.0.168",
    "convex": "^1.31.7",
    "convex-ents": "^0.16.0",
    "convex-helpers": "^0.1.106",
    "jose": "^6.1.3",
    "plaid": "^41.0.0",
    "resend": "^6.5.2",
    "svix": "^1.81.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "convex-test": "^0.0.40",
    "typescript": "^5.9.2",
    "vitest": "^3.0.0"
  }
