{
  "name": "@repo/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "convex dev --tail-logs",
    "deploy": "convex deploy",
    "setup": "convex dev --once",
    "typecheck": "tsc --noEmit",
    "lint:prompt-drift": "bun run scripts/lint-prompt-drift.ts",
    "test": "vitest run --typecheck",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --typecheck --clearScreen false"
  },
  "exports": {
    "./_generated/api": "./convex/_generated/api.js",
    "./_generated/dataModel": "./convex/_generated/dataModel.js",
    "./schema": "./convex/schema.ts",
    "./types": "./convex/types.ts",
    "./functions": "./convex/functions.ts",
    "./permissions": "./convex/permissions.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@clerk/backend": "^3.4.9",
    "@convex-dev/agent": "^0.6.1",
    "@convex-dev/rag": "^0.7.4",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "^0.2.4",
    "@convex-dev/workflow": "^0.3.12",
    "@crowdevelopment/convex-plaid": "workspace:*",
    "@internationalized/date": "^3.12.1",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@react-stately/utils": "^3.12.0",
    "@repo/email": "workspace:*",
    "ai": "^6.0.184",
    "convex": "^1.39.1",
    "convex-ents": "^0.20.0",
    "convex-helpers": "^0.1.118",
    "jose": "^6.2.3",
    "plaid": "^42.2.0",
    "resend": "^6.12.3",
    "svix": "^1.93.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "convex-test": "^0.0.52",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
