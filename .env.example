# Convex Configuration
# Run `npx convex dev` to get these values
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk Authentication
# Get these from your Clerk dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Frontend API URL (from JWT template in Clerk dashboard)
# Create a JWT template named "convex" and copy the Issuer URL here
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=https://your-clerk-domain.clerk.accounts.dev

# Clerk Redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Marketing Site URL
NEXT_PUBLIC_MARKETING_URL=https://smartpockets.com

# Note: CLERK_WEBHOOK_SECRET should be set in Convex dashboard, not here
# When you set up webhooks in Clerk, add the signing secret to your Convex
# dashboard under Settings > Environment Variables

# AI Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# AI Configuration (optional)
# Default model for chat responses
AI_DEFAULT_MODEL=claude-sonnet-4-20250514
