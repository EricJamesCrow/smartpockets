    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "qr-code-styling": "^1.9.2",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-plaid-link": "^4.1.1",
    "react-svg-credit-card-payment-icons": "^5.1.2",
    "recharts": "^3.7.0",
    "resend": "^6.5.2",
    "streamdown": "~2.5.0",
    "tailwindcss": "^4.1.11",
    "use-stick-to-bottom": "^1.1.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.27",
    "@playwright/test": "^1.59.1",
    "@repo/typescript": "workspace:*",
    "@types/node": "^24.2.1",
    "@types/react": "^19.1.9",
