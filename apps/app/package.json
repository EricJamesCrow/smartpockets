{
  "name": "@repo/app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3000 --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "clean": "rm -rf .next .turbo node_modules",
    "typecheck": "tsc --noEmit",
    "lint": "bun scripts/check-tool-results.ts && node scripts/verify-reserved-slugs.mjs && bun run test:vercel-build",
