{
  "name": "smartpockets",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tooling/*"
  ],
  "scripts": {
    "dev": "turbo dev --parallel --filter=!@crowdevelopment/convex-plaid",
    "dev:local": "bash scripts/dev-local.sh",
    "dev:app": "turbo dev --filter=@repo/app",
    "dev:web": "turbo dev --filter=@repo/web",
    "dev:email": "turbo dev --filter=@repo/email",
    "dev:backend": "turbo dev --filter=@repo/backend",
    "build": "turbo build",
    "start:app": "turbo start --filter=@repo/app",
    "start:web": "turbo start --filter=@repo/web",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "clean:workspaces": "git clean -xdf node_modules"
  },
  "packageManager": "bun@1.3.13",
  "trustedDependencies": [
    "@clerk/shared",
    "@tailwindcss/oxide",
    "esbuild",
    "lightningcss",
    "sharp"
  ],
  "overrides": {
    "axios": "^1.16.1",
    "follow-redirects": "^1.16.0"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.9",
    "@clerk/nextjs": "^7.3.5",
    "@clerk/themes": "^2.4.57",
    "@crowdevelopment/convex-plaid": "workspace:*",
    "@floating-ui/dom": "^1.7.6",
    "@react-aria/utils": "^3.34.0",
    "@react-email/components": "^1.0.12",
    "@react-email/tailwind": "^2.0.7",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/core": "^3.23.4",
    "@tiptap/extension-image": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-text-align": "^3.23.4",
    "@tiptap/extension-text-style": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@untitledui/file-icons": "^0.0.9",
    "@untitledui/icons": "^0.0.22",
    "convex": "^1.39.1",
    "convex-ents": "^0.20.0",
    "convex-helpers": "^0.1.118",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "motion": "^12.38.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "qr-code-styling": "^1.9.2",
    "react": "19.2.6",
    "react-aria": "^3.48.0",
    "react-aria-components": "^1.17.0",
    "react-dom": "19.2.6",
    "react-hotkeys-hook": "^5.3.2",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "sonner": "^2.0.7",
    "svix": "^1.93.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript": "workspace:*",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "lightningcss-linux-x64-gnu": "1.32.0",
    "postcss": "^8.5.14",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  }
}
