{
  "name": "smartpockets",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tooling/*"
  ],
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:app": "turbo dev --filter=@repo/app",
    "dev:web": "turbo dev --filter=@repo/web",
    "dev:email": "turbo dev --filter=@repo/email",
    "dev:backend": "turbo dev --filter=@repo/backend",
    "build": "turbo build",
    "start:app": "turbo start --filter=@repo/app",
    "start:web": "turbo start --filter=@repo/web",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "clean:workspaces": "git clean -xdf node_modules"
  },
  "packageManager": "bun@1.1.42",
  "trustedDependencies": [
    "@clerk/shared",
    "@tailwindcss/oxide",
    "esbuild",
    "lightningcss",
    "sharp"
  ],
  "dependencies": {
    "@clerk/backend": "^2.24.0",
    "@clerk/nextjs": "^6.36.5",
    "@clerk/themes": "^2.4.40",
    "@crowdevelopment/convex-plaid": "^0.7.1",
    "@floating-ui/dom": "^1.7.4",
    "@react-aria/utils": "^3.31.0",
    "@react-email/components": "^0.4.0",
    "@react-email/tailwind": "^1.2.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.16",
    "@tiptap/core": "^3.0.9",
    "@tiptap/extension-image": "^3.0.9",
    "@tiptap/extension-placeholder": "^3.0.9",
    "@tiptap/extension-text-align": "^3.0.9",
    "@tiptap/extension-text-style": "^3.0.9",
    "@tiptap/pm": "^3.0.9",
    "@tiptap/react": "^3.0.9",
    "@tiptap/starter-kit": "^3.0.9",
    "@untitledui/file-icons": "^0.0.9",
    "@untitledui/icons": "^0.0.19",
    "convex": "^1.31.7",
    "convex-ents": "^0.16.0",
    "convex-helpers": "^0.1.106",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "motion": "^12.23.12",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "qr-code-styling": "^1.9.2",
    "react": "19.1.1",
    "react-aria": "^3.44.0",
    "react-aria-components": "^1.13.0",
    "react-dom": "19.1.1",
    "react-hotkeys-hook": "^5.1.0",
    "recharts": "^3.1.2",
    "resend": "^6.5.2",
    "sonner": "^2.0.7",
    "svix": "^1.81.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@repo/typescript": "workspace:*",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^24.2.1",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "lightningcss-linux-x64-gnu": "1.30.1",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.7.4",
    "typescript": "^5.9.2"
  }
}
